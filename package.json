{
  "name": "tapbomb",
  "version": "2.0.0",
  "private": true,
  "description": "TAPBOMB — CS2 Tap-to-Earn Game",
  "workspaces": [
    "packages/*",
    "apps/*",
    "bot"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/server & npm run dev --workspace=apps/client",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:client": "npm run dev --workspace=apps/client",
    "dev:bot": "npm run dev --workspace=bot",
    "build": "npm run build --workspaces",
    "start": "node apps/server/dist/index.js",
    "start:bot": "node bot/dist/index.js",
    "db:migrate": "npm run migrate --workspace=apps/server",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20"
  }
}
